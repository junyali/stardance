<%# Slim sticky bar with the T-minus countdown to launch.
    Target is hard-set; controller computes the delta client-side and
    hides the element after it passes. %>
<% target_iso = "2026-06-01T16:00:00Z" # June 1 2026 noon EDT (UTC-4) %>
<div class="countdown-bar"
     data-controller="countdown-clock"
     data-countdown-clock-target-iso-value="<%= target_iso %>"
     aria-hidden="true">
  <span class="countdown-bar__label countdown-bar__label--launch">LAUNCH</span>
  <span class="countdown-bar__label countdown-bar__label--clock">CLOCK</span>
</div>
