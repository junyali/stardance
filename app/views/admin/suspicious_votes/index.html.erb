<% content_for :title, "Suspicious Votes" %>
<h1>Suspicious Votes</h1>

<div>
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>User</th>
        <th>Suspicious Votes</th>
        <th>Last Updated</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each_with_index do |user, idx| %>
        <tr>
          <td><%= idx + 1 %></td>
          <td><%= link_to user.display_name || "User ##{user.id}", admin_user_path(user) %></td>
          <td><%= user.suspicious_votes_count %></td>
          <td>
            <% if timestamp = @voting_lock_timestamps[user.id] %>
              <%= time_ago_in_words(timestamp) %> ago
            <% else %>
              <span>—</span>
            <% end %>
          </td>
          <td>
            <%= link_to "View Votes", votes_admin_user_path(user) %>
            <%= button_to toggle_voting_lock_admin_user_path(user),
                  method: :post,
                  title: user.voting_locked? ? "Unlock Voting" : "Lock Voting",
                  form: { onsubmit: "return confirm(#{("Are you sure you want to #{user.voting_locked? ? "unlock" : "lock"} voting for #{user.display_name}?").to_json})" } do %>
              <%= user.voting_locked? ? "Unlock" : "Lock" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<br>
<%= link_to "← Back to Users", admin_users_path %>
