<div>
  <%= form_with model: shop_item.becomes(ShopItem), url: (shop_item.persisted? ? admin_shop_item_path(shop_item) : admin_shop_items_path), method: (shop_item.persisted? ? :patch : :post), local: true do |f| %>
    <% if shop_item.errors.any? %>
      <div>
        <h4><%= pluralize(shop_item.errors.count, "error") %> prohibited this shop item from being saved:</h4>
        <ul>
          <% shop_item.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <div>
        <div>
          <h3>Basic Information</h3>

          <div>
            <%= f.label :type %>
            <%= f.select :type, @shop_item_types, { include_blank: "Select a type" }, {  id: "shop_item_type" } %>
          </div>

          <div>
            <%= f.label :name %>
            <%= f.text_field :name, required: true %>
          </div>

          <div>
            <%= f.label :description %>
            <%= f.text_area :description, rows: 3, required: true %>
          </div>

          <div data-controller="markdown-preview" data-markdown-preview-url-value="<%= preview_markdown_admin_shop_items_path %>">
            <%= f.label :long_description, "Extended Description (Markdown)" %>
            <div>
              <%= f.text_area :long_description, rows: 8, placeholder: "Supports **bold**, *italic*, [links](url), lists, and more...", data: { markdown_preview_target: "input", action: "input->markdown-preview#update" } %>
              <div data-markdown-preview-target="preview"></div>
            </div>
            <span>Detailed description shown on the order page. Supports Markdown formatting.</span>
          </div>

          <div>
            <%= f.label :internal_description, "Internal Description (admin only)" %>
            <%= f.text_area :internal_description, rows: 2 %>
          </div>

          <div>
            <%= f.label :image %>
            <%= f.file_field :image, required: !shop_item.persisted? %>
            <% if shop_item.persisted? && shop_item.image.attached? %>
              <div>
                <span>Current image:</span>
                <%= image_tag shop_item.image.variant(:carousel_sm) %>
              </div>
            <% end %>
          </div>
        </div>

        <div>
          <h3>Pricing</h3>

          <div>
            <div>
              <%= f.label :usd_cost, "USD Cost ($)" %>
              <%= f.number_field :usd_cost, step: 0.01, min: 0, id: "shop_item_usd_cost", placeholder: "0.00" %>
              <span>Real-world cost of this item</span>
            </div>
            <div>
              <%= f.label :hacker_score, "Hacker Score" %>
              <%= f.number_field :hacker_score, min: 0, max: 100, value: (shop_item.hacker_score || 50), id: "shop_item_hacker_score" %>
              <span>0 = easy to buy, 100 = hackers only</span>
            </div>
          </div>

          <div>
            <div>
              <%= f.label :ticket_cost do %><%= stardust_icon %> Stardust Cost<% end %>
              <%= f.number_field :ticket_cost, step: "any", id: "shop_item_ticket_cost", required: true %>
              <span>Auto-calculated from USD & Hacker Score, or set manually</span>
            </div>
            <div>
              <%= f.label :sale_percentage, "Sale (%)" %>
              <%= f.number_field :sale_percentage, min: 0, max: 100, placeholder: "0" %>
              <span>Discount off base price</span>
            </div>
          </div>

          <div>
            <div>
              <span>Suggested Tickets</span>
              <span id="estimated_tickets">—</span>
            </div>
            <div>
              <span>Est. Hours to Earn</span>
              <span id="average_hours_estimated">—</span>
            </div>
          </div>
        </div>

        <div>
          <h3>Availability</h3>

          <div>
            <% unless current_user.shop_manager? && !current_user.admin? %>
              <label>
                <%= f.check_box :enabled, id: "shop_item_enabled" %>
                <span>
                  <strong>Enabled</strong>
                  <span>Item is visible and purchasable in the shop</span>
                </span>
              </label>

              <label>
                <%= f.check_box :unlisted %>
                <span>
                  <strong>Unlisted</strong>
                  <span>Hidden from shop and API, but accessible via direct link</span>
                </span>
              </label>

              <label>
                <%= f.check_box :show_in_carousel %>
                <span>
                  <strong>Show in Carousel</strong>
                  <span>Feature this item in the homepage carousel</span>
                </span>
              </label>
            <% end %>

            <label>
              <%= f.check_box :one_per_person_ever %>
              <span>
                <strong>One Per Person</strong>
                <span>Users can only purchase this item once ever</span>
              </span>
            </label>

            <label>
              <%= f.check_box :limited, id: "shop_item_limited" %>
              <span>
                <strong>Limited Stock</strong>
                <span>Enable inventory tracking for this item</span>
              </span>
            </label>

            <label>
              <%= f.check_box :requires_verification_call %>
              <span>
                <strong>Requires Call</strong>
                <span>Orders require a verification call before fulfillment</span>
              </span>
            </label>
          </div>

          <div id="stock_field_container">
            <%= f.label :stock, "Stock Quantity" %>
            <%= f.number_field :stock, min: 0, id: "shop_item_stock" %>
            <span>Number of items available for purchase</span>
          </div>

          <% unless current_user.shop_manager? && !current_user.admin? %>
            <div>
              <%= f.label :enabled_until, "Enabled Until" %>
              <%= f.datetime_local_field :enabled_until %>
              <span>If set, the item will auto-disable after this date. Leave blank to keep enabled indefinitely.</span>
            </div>
          <% end %>

          <div>
            <%= f.label :max_qty, "Max Per Order" %>
            <%= f.number_field :max_qty, min: 1, placeholder: "Unlimited" %>
            <span>Maximum quantity a user can add to a single order</span>
          </div>

          <div>
            <%= f.label :past_purchases, "Past Purchases" %>
            <%= f.number_field :past_purchases, min: 0, placeholder: "0" %>
            <span>Historical purchase numbers (if we got em)</span>
          </div>

          <div>
            <label>
              <%= f.check_box :requires_ship, id: "shop_item_requires_ship" %>
              <span>
                <strong>Requires Shipped Project</strong>
                <span>User must have shipped projects in a date range to purchase</span>
              </span>
            </label>

          </div>

          <div>
            <%= f.label :requires_achievement, "Requires Achievements" %>
            <div>
              <%= f.collection_check_boxes :requires_achievement, Achievement.all.select { |a| !a.hidden? }, ->(a) { a.slug.to_s }, ->(a) { "#{a.name} (#{a.slug})" } do |b| %>
                <label>
                  <%= b.check_box %>
                  <span><%= b.text %></span>
                </label>
              <% end %>
            </div>
            <span>User must have earned AT LEAST ONE of the selected achievements to purchase. You can select multiple by checking the boxes.</span>
          </div>

          <div>
            <label>
              <%= f.check_box :mission_prize_only %>
              <span>
                <strong>Mission prize only</strong>
                <span>Hidden from catalog. Claimable only via the mission redemption flow.</span>
              </span>
            </label>
          </div>

          <div>
            <%= f.label :unlocking_mission_ids, "Unlocked by Missions" %>
            <div>
              <% Mission.not_deleted.order(:name).each do |mission| %>
                <label>
                  <%= check_box_tag "shop_item[unlocking_mission_ids][]", mission.id, shop_item.unlocking_mission_ids.include?(mission.id), id: "shop_item_unlocking_mission_ids_#{mission.id}" %>
                  <span><%= mission.name %> (<%= mission.slug %>)</span>
                </label>
              <% end %>
            </div>
            <span>User must have completed AT LEAST ONE of these missions to purchase. Leave empty for no mission gate.</span>
          </div>

          <div id="ship_requirement_fields">
            <div>
              <%= f.label :required_ships_count, "Required Ships Count" %>
              <%= f.number_field :required_ships_count, min: 1, value: (shop_item.required_ships_count || 1), id: "shop_item_required_ships_count" %>
              <span>Minimum number of projects shipped in the date range</span>
            </div>

            <div>
              <div>
                <%= f.label :required_ships_start_date, "Ships Required From" %>
                <%= f.date_field :required_ships_start_date, id: "shop_item_required_ships_start_date" %>
                <span>Start of the eligibility date range</span>
              </div>
              <div>
                <%= f.label :required_ships_end_date, "Ships Required Until" %>
                <%= f.date_field :required_ships_end_date, id: "shop_item_required_ships_end_date" %>
                <span>End of the eligibility date range</span>
              </div>
            </div>
          </div>

        </div>

        <div id="hack_clubber_settings">
          <h3>Hack Clubber Settings</h3>
          <div>
            <%= f.label :user_id, "Seller (User ID)" %>
            <%= f.number_field :user_id, placeholder: "User ID" %>
            <span>The ID of the Hack Clubber selling this item</span>
          </div>
          <div>
            <%= f.label :payout_percentage, "Payout Percentage (%)" %>
            <%= f.number_field :payout_percentage, min: 0, max: 100 %>
            <span>Percentage of the sale price that goes to the seller</span>
          </div>
        </div>

        <div id="hcb_locks_settings">
          <h3>HCB Locks</h3>
          <div>
            <%= f.label :hcb_merchant_lock, "HCB Merchant Lock" %>
            <%= f.text_field :hcb_merchant_lock %>
          </div>
          <div>
            <%= f.label :hcb_category_lock, "HCB Category Lock" %>
            <%= f.text_field :hcb_category_lock %>
          </div>
          <div>
            <%= f.label :hcb_keyword_lock, "HCB Keyword Lock" %>
            <%= f.text_field :hcb_keyword_lock %>
          </div>

          <div>
            <label>
              <%= f.check_box :hcb_one_time_use %>
              <span>
                <strong>One-Time Use</strong>
                <span>freeze card after one txn</span>
              </span>
            </label>
          </div>
        </div>

        <div id="hcb_preauth_settings">
          <h3>HCB Preauthorization</h3>
          <div>
            <%= f.label :hcb_preauthorization_instructions, "Preauthorization Instructions" %>
            <%= f.text_area :hcb_preauthorization_instructions, rows: 3, placeholder: "Instructions for preauthorized HCB grants" %>
            <span>Used by HCB Preauth Grant items to provide spending instructions</span>
          </div>
        </div>

        <div id="warehouse_settings">
          <h3>Warehouse Settings</h3>
          <div>
            <%= f.label :agh_contents, "AGH Contents (JSON)" %>
            <%= f.text_area :agh_contents, rows: 4, id: "shop_item_agh_contents", placeholder: '[{"sku": "ITEM-001", "quantity": 1}]', value: shop_item.agh_contents.present? ? JSON.pretty_generate(shop_item.agh_contents) : '' %>
            <span>List SKUs to include. Quantity selected by user will batch all SKUs together.</span>
            <div>
              <strong>Required:</strong> This field must contain valid JSON (not Ruby hash syntax).
              Use double quotes for keys and strings. <a href="https://github.com/hackclub/stardance/issues/1172" target="_blank" rel="noopener">See issue #1172 for more info</a>.
            </div>
          </div>
        </div>

        <div id="source_region_settings">
          <h3>Source Region</h3>
          <div>
            <%= f.label :source_region, "Source Region" %>
            <%= f.select :source_region,
              [["None (use default behavior)", ""]] + Shop::Regionalizable::REGIONS.map { |code, config| [config[:name], code] },
              {} %>
            <span>If you set this, people will get a scary warning if the selected address is outside this region.</span>
          </div>
        </div>

        <div>
          <h3>Country Blacklist</h3>
          <div>
            <%= f.label :blocked_countries, "Blocked Countries" %>
            <%= f.select :blocked_countries,
                ISO3166::Country.all.sort_by { |c| c.common_name.presence || c.iso_short_name }.map { |c| [c.common_name.presence || c.iso_short_name, c.alpha2] },
                { include_hidden: false },
                { multiple: true, size: 8 } %>
            <span>Select countries to block. Addresses with these countries will be blocked, even if the item is enabled for their region. This trumps all other regional restrictions.</span>
          </div>
        </div>

        <div id="accessory_settings">
          <h3>Accessory Settings</h3>
          <label>
            <%= f.check_box :buyable_by_self, id: "shop_item_buyable_by_self" %>
            <span>Buyable By Self</span>
          </label>
          <span>If unchecked, this accessory can only be purchased with an attached item</span>

          <div>
            <%= f.label :accessory_tag, "Accessory Tag" %>
            <%= f.text_field :accessory_tag, placeholder: "e.g., color_item, ram_type" %>
            <span>Accessories with the same tag are mutually exclusive (only one can be selected)</span>
          </div>

          <label>
            <%= f.check_box :show_image_in_shop, id: "shop_item_show_image_in_shop" %>
            <span>Show Image in Shop</span>
          </label>
          <span>Display this accessory's image on the order page</span>

          <div>
            <%= f.label :attached_shop_item_ids, "Attached To (Shop Items)" %>
            <div>
              <%= f.collection_check_boxes :attached_shop_item_ids, ShopItem.where.not(type: "ShopItem::Accessory").order(:name), :id, :name do |b| %>
                <label>
                  <%= b.check_box %>
                  <span><%= b.text %></span>
                </label>
              <% end %>
            </div>
            <span>Select items this accessory can be attached to</span>
          </div>
        </div>
      </div>

      <div>
        <div>
          <h3>Actions</h3>
          <div>
            <%= f.submit shop_item.persisted? ? "Update Item" : "Create Item" %>
            <%= link_to "Cancel", admin_manage_shop_path %>
          </div>
        </div>
      </div>
    </div>

    <div>
      <h3>Regional Availability & Pricing</h3>

      <div>
        <strong>Regional Logic:</strong>
        <br><strong>XX (Rest of World):</strong> Items enabled for XX appear in <em>all</em> regions using XX pricing
        <br><strong>Specific Regions:</strong> Items enabled for specific regions (US, EU, etc.) only appear in those
        regions
        <br><strong>Priority:</strong> Regional pricing takes precedence over XX pricing when both are enabled
      </div>

      <div>
        <table>
          <thead>
          <tr>
            <th>Region</th>
            <th>Enabled</th>
            <th>Default Assignee</th>
            <th>Δ USD</th>
            <th>Δ Hours</th>
            <th>Δ Tickets</th>
            <th>Final Price</th>
            <th>Est. Hours</th>
          </tr>
          </thead>
          <tbody>
          <% Shop::Regionalizable::REGIONS.each do |code, config| %>
            <%
              flag = case code
                     when "US" then "🇺🇸"
                     when "EU" then "🇪🇺"
                     when "UK" then "🇬🇧"
                     when "CA" then "🇨🇦"
                     when "AU" then "🇦🇺"
                     when "IN" then "🇮🇳"
                     when "XX" then "🌍"
                     else "🏳️"
                     end
            %>
            <tr>
              <td>
                <span><%= flag %></span>
                <strong><%= config[:name] %></strong>
              </td>
              <td>
                <%= f.check_box "enabled_#{code.downcase}", data: { region: code.downcase } %>
              </td>
              <td>
                <%= f.select "default_assigned_user_id_#{code.downcase}",
                    @fulfillment_users.map { |u| [u.display_name, u.id] },
                    { include_blank: "None", selected: shop_item.send("default_assigned_user_id_#{code.downcase}") },
                    {  style: "width: 120px;" } %>
              </td>
              <td>
                <%= f.number_field "usd_offset_#{code.downcase}", step: 0.01, data: { region: code.downcase }, placeholder: "0.00", value: shop_item.send("usd_offset_#{code.downcase}") %>
              </td>
              <td>
                <input type="number" step="0.1" data-region="<%= code.downcase %>" placeholder="0.0" autocomplete="off">
              </td>
              <td>
                <code data-region="<%= code.downcase %>">0</code>
              </td>
              <td>
                <code data-region="<%= code.downcase %>">
                  <%= shop_item.base_price_for_region(code).to_i %>
                </code>
              </td>
              <td>
                <span data-region="<%= code.downcase %>">0.0</span>
              </td>
            </tr>
          <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>

<script>
    (function () {
        const gameConstants = {
            doubloons_per_dollar: <%= Rails.configuration.game_constants.tickets_per_dollar.to_json %>,
            dollars_per_mean_hour: <%= Rails.configuration.game_constants.dollars_per_mean_hour.to_json %>
        };

        const usdCostField = document.getElementById('shop_item_usd_cost');
        const ticketCostField = document.getElementById('shop_item_ticket_cost');
        const hackerScoreField = document.getElementById('shop_item_hacker_score');
        const estimatedTicketsDisplay = document.getElementById('estimated_tickets');
        const averageHoursDisplay = document.getElementById('average_hours_estimated');

        let isTicketCostManuallySet = false;

        if (ticketCostField && ticketCostField.value && parseFloat(ticketCostField.value) !== 0) {
            isTicketCostManuallySet = true;
            ticketCostField.value = Math.round(parseFloat(ticketCostField.value));
        }

        function calculateEstimatedTickets() {
            const usdCost = parseFloat(usdCostField.value) || 0;
            const hackerScore = parseFloat(hackerScoreField.value) || 50;
            const hackerScorePercent = hackerScore / 100;
            const estimatedTickets = gameConstants.doubloons_per_dollar * usdCost * (0.5 + (1 - hackerScorePercent));
            return estimatedTickets;
        }

        function calculateAverageHours() {
            const ticketCost = parseFloat(ticketCostField.value) || 0;
            const averageHours = ticketCost / (gameConstants.doubloons_per_dollar * gameConstants.dollars_per_mean_hour);
            return averageHours;
        }

        function updateCalculations() {
            const estimatedTickets = calculateEstimatedTickets();
            const averageHours = calculateAverageHours();
            if (estimatedTicketsDisplay) {
                estimatedTicketsDisplay.textContent = estimatedTickets > 0 ? Math.round(estimatedTickets) : '—';
            }
            if (averageHoursDisplay) {
                averageHoursDisplay.textContent = averageHours > 0 ? averageHours.toFixed(1) + 'h' : '—';
            }
        }

        function autoFillTicketCost() {
            if (isTicketCostManuallySet) return;

            const estimatedTickets = calculateEstimatedTickets();
            if (usdCostField.value) {
                ticketCostField.value = Math.round(estimatedTickets);
                updateCalculations();
                updateAllRegionalPricing();
            }
        }

        if (usdCostField) {
            usdCostField.addEventListener('input', function () {
                updateCalculations();
                autoFillTicketCost();
            });
        }

        if (ticketCostField) {
            ticketCostField.addEventListener('input', function (e) {
                if (e.isTrusted) {
                    isTicketCostManuallySet = true;
                    if (this.value === '' || parseFloat(this.value) === 0) {
                        isTicketCostManuallySet = false;
                        autoFillTicketCost();
                    }
                }
                updateCalculations();
                updateAllRegionalPricing();
            });
        }

        if (hackerScoreField) {
            hackerScoreField.addEventListener('input', function () {
                updateCalculations();
                autoFillTicketCost();
                updateAllRegionalPricing();
            });
        }

        const limitedCheckbox = document.getElementById('shop_item_limited');
        const stockFieldContainer = document.getElementById('stock_field_container');

        function toggleStockField() {
            if (limitedCheckbox && stockFieldContainer) {
                stockFieldContainer.style.display = limitedCheckbox.checked ? 'block' : 'none';
            }
        }

        if (limitedCheckbox) {
            limitedCheckbox.addEventListener('change', toggleStockField);
            toggleStockField();
        }

        const requiresShipCheckbox = document.getElementById('shop_item_requires_ship');
        const shipRequirementFields = document.getElementById('ship_requirement_fields');

        function toggleShipRequirementFields() {
            if (requiresShipCheckbox && shipRequirementFields) {
                shipRequirementFields.style.display = requiresShipCheckbox.checked ? 'block' : 'none';
            }
        }

        if (requiresShipCheckbox) {
            requiresShipCheckbox.addEventListener('change', toggleShipRequirementFields);
            toggleShipRequirementFields();
        }

        function getHackerMultiplier() {
            const hackerScore = parseFloat(hackerScoreField.value) || 50;
            return 0.5 + (1 - hackerScore / 100);
        }

        // usd_offset is the canonical stored value. All other regional fields derive from it.
        function updateFromUsdOffset(region, skipHours = false) {
            const basePrice = parseFloat(ticketCostField.value) || 0;
            const usdOffsetField = document.querySelector(`[data-region="${region}"].usd-offset`);
            const usdOffset = parseFloat(usdOffsetField.value) || 0;
            const hackerMultiplier = getHackerMultiplier();

            const deltaTickets = usdOffset * gameConstants.doubloons_per_dollar * hackerMultiplier;
            const finalPrice = basePrice + deltaTickets;

            const deltaTicketsDisplay = document.querySelector(`[data-region="${region}"].delta-tickets-display`);
            if (deltaTicketsDisplay) deltaTicketsDisplay.textContent = Math.round(deltaTickets);

            const finalPriceSpan = document.querySelector(`[data-region="${region}"].shop-item-form__final-price`);
            if (finalPriceSpan) finalPriceSpan.textContent = Math.round(finalPrice);

            const estimatedHours = finalPrice / (gameConstants.doubloons_per_dollar * gameConstants.dollars_per_mean_hour);
            const estimatedHoursSpan = document.querySelector(`[data-region="${region}"].estimated-hours`);
            if (estimatedHoursSpan) estimatedHoursSpan.textContent = estimatedHours.toFixed(1);

            if (!skipHours) {
                // delta_hours = usd_offset * hacker_multiplier / dollars_per_mean_hour
                const deltaHours = usdOffset * hackerMultiplier / gameConstants.dollars_per_mean_hour;
                const deltaHoursInput = document.querySelector(`[data-region="${region}"].delta-hours-input`);
                if (deltaHoursInput) deltaHoursInput.value = deltaHours.toFixed(1);
            }
        }

        function updateFromDeltaHours(region) {
            const deltaHoursInput = document.querySelector(`[data-region="${region}"].delta-hours-input`);
            const deltaHours = parseFloat(deltaHoursInput.value) || 0;
            const hackerMultiplier = getHackerMultiplier();
            // usd_offset = delta_hours * dollars_per_mean_hour / hacker_multiplier
            const usdOffset = hackerMultiplier > 0
                ? (deltaHours * gameConstants.dollars_per_mean_hour / hackerMultiplier)
                : 0;
            const usdOffsetField = document.querySelector(`[data-region="${region}"].usd-offset`);
            if (usdOffsetField) usdOffsetField.value = usdOffset.toFixed(2);
            updateFromUsdOffset(region, true);
        }

        function updateAllRegionalPricing() {
            document.querySelectorAll('.usd-offset').forEach(field => {
                updateFromUsdOffset(field.dataset.region);
            });
        }

        document.querySelectorAll('.usd-offset').forEach(field => {
            field.addEventListener('input', function () {
                updateFromUsdOffset(this.dataset.region);
            });
        });

        document.querySelectorAll('.delta-hours-input').forEach(field => {
            field.addEventListener('input', function () {
                updateFromDeltaHours(this.dataset.region);
            });
        });

        updateCalculations();
        autoFillTicketCost();
        updateAllRegionalPricing();

        const typeSelect = document.getElementById('shop_item_type');
        const hackClubberSettings = document.getElementById('hack_clubber_settings');
        const hcbLocksSettings = document.getElementById('hcb_locks_settings');
        const hcbPreauthSettings = document.getElementById('hcb_preauth_settings');
        const warehouseSettings = document.getElementById('warehouse_settings');
        const accessorySettings = document.getElementById('accessory_settings');
        const sourceSettings = document.getElementById('source_region_settings');
        const aghContentsField = document.getElementById('shop_item_agh_contents');

        const SOURCE_REGION_TYPES = ['ShopItem::HackClubberItem', 'ShopItem::ThirdPartyDigital', 'ShopItem::HQMailItem'];
        // we can add more later, but for now, just these three

        function updateTypeVisibility() {
            const selectedType = typeSelect ? typeSelect.value : '';

            if (hackClubberSettings) {
                hackClubberSettings.style.display = (selectedType === 'ShopItem::HackClubberItem') ? 'block' : 'none';
            }

            if (hcbLocksSettings) {
                hcbLocksSettings.style.display = (selectedType === 'ShopItem::HCBGrant' || selectedType === 'ShopItem::HCBPreauthGrant') ? 'block' : 'none';
            }

            if (hcbPreauthSettings) {
                hcbPreauthSettings.style.display = (selectedType === 'ShopItem::HCBPreauthGrant') ? 'block' : 'none';
            }

            if (warehouseSettings) {
                warehouseSettings.style.display = (selectedType === 'ShopItem::WarehouseItem' || selectedType === 'ShopItem::PileOfStickersItem') ? 'block' : 'none';
            }

            if (aghContentsField) {
                aghContentsField.required = (selectedType === 'ShopItem::WarehouseItem');
            }

            if (accessorySettings) {
                accessorySettings.style.display = (selectedType === 'ShopItem::Accessory') ? 'block' : 'none';
            }

            if (sourceSettings) {
                sourceSettings.style.display = SOURCE_REGION_TYPES.includes(selectedType) ? 'block' : 'none';
            }
        }

        if (typeSelect) {
            typeSelect.addEventListener('change', updateTypeVisibility);
            updateTypeVisibility();
        }
    })();
</script>
