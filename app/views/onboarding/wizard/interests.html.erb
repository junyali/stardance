<% content_for :title, "Interests" %>
<main class="onboarding-screen onboarding-screen--interests" data-controller="onboarding-transition">
  <%= render Onboarding::ProgressBarComponent.new(step: :interests) %>

  <div class="onboarding-screen__content">
    <p class="onboarding-screen__eyebrow">ok anywayssssss</p>
    <h1 class="onboarding-screen__title onboarding-screen__title--lower">what kind of stuff do u like?</h1>
    <p class="onboarding-screen__subhead">pick as many as you want !!!!!!!!!!!!!!!!!!!!!!!!!</p>

    <%= form_with url: onboarding_interests_path, method: :post, local: true,
                   data: { controller: "onboarding-interests", action: "change->onboarding-interests#refresh" },
                   class: "onboarding-interests__form" do |f| %>
      <div class="onboarding-interests__grid">
        <% User::ALLOWED_INTERESTS.each do |slug| %>
          <label class="onboarding-interests__tile">
            <%= check_box_tag "interests[]", slug, @selected.include?(slug),
                              class: "onboarding-interests__checkbox" %>
            <span class="onboarding-interests__label"><%= slug.tr("_", " ") %></span>
          </label>
        <% end %>
      </div>
      <%= render SpecialActionButtonComponent.new(
            text: "Next",
            type: :submit,
            disabled: @selected.empty?,
            class: "onboarding-interests__submit",
            data: {
              onboarding_interests_target: "submit",
              action: "click->onboarding-transition#press"
            }
          ) %>
    <% end %>
  </div>
</main>
